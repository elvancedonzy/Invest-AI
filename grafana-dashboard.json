{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Invest AI Portfolio",
  "uid": "invest-ai-v1",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "tags": ["invest-ai"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Market Regime",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"color": "red",    "value": 0},
            {"color": "orange", "value": 1},
            {"color": "yellow", "value": 2},
            {"color": "yellow", "value": 3},
            {"color": "green",  "value": 4}
          ]
        },
        "mappings": [
          {"type": "value", "options": {"0": {"text": "CRASH"}, "1": {"text": "BEAR"}, "2": {"text": "CHOPPY"}, "3": {"text": "NEUTRAL"}, "4": {"text": "BULL"}}}
        ]
      },
      "targets": [{"expr": "invest_ai_regime", "legendFormat": "Regime", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Kevin Hit Rate",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "unit": "percent",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"color": "red",    "value": 0},
            {"color": "yellow", "value": 40},
            {"color": "green",  "value": 55}
          ]
        }
      },
      "targets": [{"expr": "invest_ai_hit_rate", "legendFormat": "Hit Rate %", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "SPY Price",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value",
        "unit": "currencyUSD"
      },
      "targets": [{"expr": "invest_ai_spy_price", "legendFormat": "SPY", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "20d Ann. Volatility",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "unit": "percent",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"color": "green",  "value": 0},
            {"color": "yellow", "value": 20},
            {"color": "red",    "value": 35}
          ]
        }
      },
      "targets": [{"expr": "invest_ai_volatility", "legendFormat": "Volatility", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Analysis Age",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "unit": "s",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"color": "green",  "value": 0},
            {"color": "yellow", "value": 3600},
            {"color": "red",    "value": 86400}
          ]
        }
      },
      "targets": [{"expr": "invest_ai_analysis_age_seconds", "legendFormat": "Age", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Reports Loaded",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value",
        "unit": "short"
      },
      "targets": [{"expr": "invest_ai_reports_total", "legendFormat": "Reports", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}]
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Trade Outcomes",
      "gridPos": {"x": 0, "y": 4, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {"pieType": "donut", "legendDisplayMode": "table", "legendPlacement": "right"},
      "targets": [
        {"expr": "invest_ai_trades{outcome=\"HIT\"}",  "legendFormat": "HIT",  "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "invest_ai_trades{outcome=\"MISS\"}", "legendFormat": "MISS", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "invest_ai_trades{outcome=\"OPEN\"}", "legendFormat": "OPEN", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ],
      "overrides": [
        {"matcher": {"id": "byName", "options": "HIT"},  "properties": [{"id": "color", "value": {"fixedColor": "#00ff88", "mode": "fixed"}}]},
        {"matcher": {"id": "byName", "options": "MISS"}, "properties": [{"id": "color", "value": {"fixedColor": "#ff6b6b", "mode": "fixed"}}]},
        {"matcher": {"id": "byName", "options": "OPEN"}, "properties": [{"id": "color", "value": {"fixedColor": "#ffd700", "mode": "fixed"}}]}
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Regime & Volatility Over Time",
      "gridPos": {"x": 8, "y": 4, "w": 16, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {"expr": "invest_ai_regime",     "legendFormat": "Regime (0-4)", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "invest_ai_volatility", "legendFormat": "Volatility %", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ]
    }
  ]
}
